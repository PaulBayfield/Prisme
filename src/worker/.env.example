# Copy to .env - read by __main__.py (the sync queue daemon) and the scripts under script/.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=Prisme
POSTGRES_USER=prisme_db
POSTGRES_PASSWORD=

# pgcrypto passphrase used to decrypt stored LCL credentials.
# Must match CREDENTIALS_ENCRYPTION_KEY in src/frontend/.env.local exactly.
CREDENTIALS_ENCRYPTION_KEY=
