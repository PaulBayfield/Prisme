# Copy to .env.local.

# Set to "true" to run the frontend against in-memory demo fixtures instead of
# PostgreSQL/Authentik - useful for a public showcase deploy or trying Prisme
# without a real LCL account. When enabled, the POSTGRES_*, AUTHENTIK_*, and
# CREDENTIALS_ENCRYPTION_KEY variables below are not read and can be left unset.
DEMO_MODE=false

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=Prisme
POSTGRES_USER=prisme_db
POSTGRES_PASSWORD=

NEXTAUTH_URL=http://localhost:3000
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your Authentik issuer URL, e.g. https://auth.example.com/application/o/prisme
AUTHENTIK_ISSUER=
# OIDC client id (Authentik admin -> Applications)
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# Authentik userinfo endpoint, e.g. https://auth.example.com/application/o/userinfo/
AUTHENTIK_USER_INFO_URL=

# pgcrypto passphrase used to decrypt stored LCL credentials.
# Must match CREDENTIALS_ENCRYPTION_KEY in src/worker/.env exactly.
CREDENTIALS_ENCRYPTION_KEY=

# Shown in the help dialog's version badge.
NEXT_PUBLIC_APP_VERSION=1.0.0
