# Copy to .env - read by docker-compose.yml to provision PostgreSQL (prisme-db).

POSTGRES_DATABASE=Prisme
POSTGRES_USER=prisme_db
POSTGRES_PASSWORD=

# Baked into the frontend's client bundle at `docker compose build` time (see
# prisme-frontend's build.args) - setting it in src/frontend/.env.local alone
# has no effect on the production image, only on `npm run dev`.
NEXT_PUBLIC_APP_VERSION=1.0.0
